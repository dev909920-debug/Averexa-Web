# ─────────────────────────────────────────────────────────
# AVEREXA PLACEMENT — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# All variables are validated at runtime via config/env.ts
# ─────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile — CAPTCHA bot protection
# Dev test site key (always passes): 1x00000000000000000000AA
# Dev test secret  (always passes):  1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Google Apps Script Web App URL — direct POST from browser (no webhook/server route)
# Handles: sheet row append, resume Drive save, email to dev + info
NEXT_PUBLIC_APPS_SCRIPT_URL=

# Google Analytics & GTM (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
